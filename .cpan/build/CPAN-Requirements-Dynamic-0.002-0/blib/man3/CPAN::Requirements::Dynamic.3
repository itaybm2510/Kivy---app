.SH NAME
CPAN::Requirements::Dynamic \- Dynamic prerequisites in meta files
.SH VERSION
.IX Header "VERSION"
version 0.002
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 10
\& my $result = $dynamic\->evaluate({
\&   expressions => [
\&     {
\&       condition => [ \*(Aqhas_perl\*(Aq => \*(Aqv5.20.0\*(Aq ],
\&       prereqs => { Bar => "1.3" },
\&     },
\&     {
\&       condition => [ is_os => \*(Aqlinux\*(Aq ],
\&       prereqs => { Baz => "1.4" },
